{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://4veco.local/references/schemas/evidence-anchor.schema.json",
  "title": "EvidenceAnchor",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "evidence_id",
    "source_path",
    "document_id",
    "source_layer",
    "authority_rank",
    "locator",
    "supports",
    "extraction_method",
    "confidence"
  ],
  "properties": {
    "evidence_id": { "type": "string", "pattern": "^EV-[A-Z0-9.-]+$" },
    "source_path": { "type": "string" },
    "document_id": { "type": "string" },
    "source_layer": {
      "type": "string",
      "enum": [
        "external_authority",
        "authored_judgement",
        "machine_registry",
        "human_gate_decision",
        "governance_data",
        "generated_report"
      ]
    },
    "authority_rank": {
      "type": "integer",
      "minimum": 1,
      "maximum": 7
    },
    "locator": {
      "type": "object",
      "additionalProperties": true,
      "minProperties": 1
    },
    "excerpt": { "type": ["string", "null"] },
    "summary": { "type": "string" },
    "supports": { "type": "string" },
    "extraction_method": {
      "type": "string",
      "enum": ["direct_record", "manual_locator", "scripted_extraction", "generated_report_summary"]
    },
    "confidence": {
      "type": "string",
      "enum": ["high", "medium", "low"]
    },
    "primary": { "type": "boolean" }
  }
}
