{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://4veco.local/references/schemas/quality-issue.schema.json",
  "title": "QualityIssue",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "issue_id",
    "title",
    "quality_category",
    "status",
    "severity",
    "owner_team",
    "affected_surface",
    "evidence_refs",
    "next_action",
    "proof_required_to_close",
    "authority_boundary",
    "created_on"
  ],
  "properties": {
    "issue_id": {
      "type": "string",
      "pattern": "^[A-Z0-9][A-Z0-9._-]+$"
    },
    "title": {
      "type": "string",
      "minLength": 8
    },
    "quality_category": {
      "type": "string",
      "enum": [
        "reference_quality",
        "evidence_sufficiency",
        "unit_design",
        "extraction_integrity",
        "report_drift",
        "source_version_drift",
        "term_link_gap",
        "needs_gap",
        "production_readiness_warning"
      ]
    },
    "status": {
      "type": "string",
      "enum": ["open", "blocked", "in_review", "deferred", "resolved"]
    },
    "severity": {
      "type": "string",
      "enum": ["info", "low", "medium", "high", "critical"]
    },
    "owner_team": {
      "type": "string",
      "enum": [
        "references_team",
        "content_strategy",
        "platform_team",
        "lessons_team",
        "cross_team"
      ]
    },
    "affected_surface": {
      "type": "string",
      "minLength": 1
    },
    "affected_entities": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "role"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "role": { "type": "string", "minLength": 1 },
          "note": { "type": "string" }
        }
      }
    },
    "next_action": {
      "type": "string",
      "minLength": 1
    },
    "proof_required_to_close": {
      "type": "string",
      "minLength": 1
    },
    "authority_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "internal_only",
        "curriculum_authority",
        "student_facing_exposure",
        "primary_evidence"
      ],
      "properties": {
        "internal_only": { "type": "boolean", "const": true },
        "curriculum_authority": { "type": "boolean", "const": false },
        "student_facing_exposure": { "type": "boolean", "const": false },
        "primary_evidence": { "type": "boolean", "const": false }
      }
    },
    "created_on": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "updated_on": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "closed_on": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "blocked_downstream_uses": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    }
  }
}
