{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://4veco.local/references/schemas/target-exercise.schema.json",
  "title": "TargetExercise",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "book", "required_units"],
  "properties": {
    "id": { "type": "string" },
    "book": { "type": "string" },
    "paragraph": { "type": ["string", "null"] },
    "required_units": { "type": "array", "items": { "type": "string" } },
    "missing_units_flagged": { "type": "array", "items": { "type": "string" } },
    "evidence_ids": { "type": "array", "items": { "type": "string" } }
  }
}
