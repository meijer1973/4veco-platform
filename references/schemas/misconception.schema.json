{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://4veco.local/references/schemas/misconception.schema.json",
  "title": "Misconception",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "misconception_id",
    "title_nl",
    "misconception_statement_nl",
    "correct_conception_nl",
    "common_trigger_nl",
    "linked_unit_ids",
    "evidence_refs",
    "affected_surfaces",
    "status",
    "severity",
    "owner_team",
    "authority_flags",
    "created_on"
  ],
  "properties": {
    "misconception_id": {
      "type": "string",
      "pattern": "^MIS-[A-Z0-9][A-Z0-9._-]+$"
    },
    "title_nl": {
      "type": "string",
      "minLength": 8
    },
    "misconception_statement_nl": {
      "type": "string",
      "minLength": 12
    },
    "correct_conception_nl": {
      "type": "string",
      "minLength": 12
    },
    "common_trigger_nl": {
      "type": "string",
      "minLength": 8
    },
    "linked_unit_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[A-Z][0-9]{2}$"
      }
    },
    "term_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9-]*$"
      },
      "default": []
    },
    "operation_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9_:-]+$"
      },
      "default": []
    },
    "formal_step_refs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["template_id", "formal_step_id", "role"],
        "properties": {
          "template_id": {
            "type": "string",
            "minLength": 1
          },
          "formal_step_id": {
            "type": "string",
            "minLength": 1
          },
          "role": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "default": []
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "role", "note"],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "role": {
            "type": "string",
            "minLength": 1
          },
          "note": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "affected_surfaces": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "exercise_design",
          "answer_model_review",
          "teacher_explanation_review",
          "reasoning_game_source",
          "procedure_visual_review",
          "rag_context"
        ]
      }
    },
    "status": {
      "type": "string",
      "enum": ["active", "candidate", "deferred", "retired"]
    },
    "severity": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "owner_team": {
      "type": "string",
      "enum": [
        "references_team",
        "content_strategy",
        "platform_team",
        "lessons_team",
        "cross_team"
      ]
    },
    "authoring_guidance_nl": {
      "type": "string"
    },
    "review_prompt_nl": {
      "type": "string"
    },
    "authority_flags": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "internal_only",
        "diagnostic_design_context",
        "primary_evidence",
        "curriculum_authority",
        "exam_authority",
        "scoring_rule",
        "student_facing_diagnosis",
        "student_facing_exposure",
        "adaptive_routing",
        "mastery_decision",
        "automatic_sequencing",
        "student_facing_ai",
        "summative_use",
        "pv_projection",
        "pv_machine_promotion",
        "machine_registry_authority"
      ],
      "properties": {
        "internal_only": { "type": "boolean", "const": true },
        "diagnostic_design_context": { "type": "boolean", "const": true },
        "primary_evidence": { "type": "boolean", "const": false },
        "curriculum_authority": { "type": "boolean", "const": false },
        "exam_authority": { "type": "boolean", "const": false },
        "scoring_rule": { "type": "boolean", "const": false },
        "student_facing_diagnosis": { "type": "boolean", "const": false },
        "student_facing_exposure": { "type": "boolean", "const": false },
        "adaptive_routing": { "type": "boolean", "const": false },
        "mastery_decision": { "type": "boolean", "const": false },
        "automatic_sequencing": { "type": "boolean", "const": false },
        "student_facing_ai": { "type": "boolean", "const": false },
        "summative_use": { "type": "boolean", "const": false },
        "pv_projection": { "type": "boolean", "const": false },
        "pv_machine_promotion": { "type": "boolean", "const": false },
        "machine_registry_authority": { "type": "boolean", "const": false }
      }
    },
    "allowed_downstream_uses": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "blocked_downstream_uses": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "created_on": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "updated_on": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "notes": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    }
  }
}
