{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://4veco.local/references/schemas/unit.schema.json",
  "title": "MicroTeachingUnit",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "name", "kern", "needs", "mastery_target"],
  "properties": {
    "id": { "type": "string", "pattern": "^[A-Z][0-9]{2}$" },
    "name": { "type": "string" },
    "kern": { "type": "string" },
    "needs": { "type": "array", "items": { "type": "string" } },
    "mastery_target": { "type": "string", "enum": ["understand", "apply", "analyze", "evaluate"] },
    "terms": { "type": "array", "items": { "type": "string" } },
    "exam_codes": { "type": "array", "items": { "type": "string" } },
    "procedure": { "type": ["string", "object", "null"] },
    "assumed_prior_knowledge": { "type": "array", "items": { "type": "string" } },
    "zero_needs_status": {
      "type": "string",
      "enum": ["true_zero", "underbouw_assumed", "false_zero", "ambiguous", "not_reviewed"]
    },
    "zero_needs_review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reviewed_on", "reviewer", "rationale", "recommended_needs", "severity"],
      "properties": {
        "reviewed_on": { "type": "string" },
        "reviewer": { "type": "string" },
        "rationale": { "type": "string" },
        "recommended_needs": { "type": "array", "items": { "type": "string" } },
        "severity": { "type": "string", "enum": ["low", "medium", "high"] }
      }
    },
    "deprecated": { "type": "boolean" }
  }
}
