{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://4veco.local/references/schemas/prior-knowledge-review.schema.json",
  "title": "PriorKnowledgeReview",
  "type": "object",
  "additionalProperties": false,
  "required": ["unit_id", "current_needs", "recommended_status", "recommended_needs", "rationale", "severity", "review_status"],
  "properties": {
    "unit_id": { "type": "string", "pattern": "^[A-Z][0-9]{2}$" },
    "current_needs": { "type": "array", "items": { "type": "string" } },
    "recommended_status": {
      "type": "string",
      "enum": ["true_zero", "underbouw_assumed", "false_zero", "ambiguous", "not_reviewed"]
    },
    "recommended_needs": { "type": "array", "items": { "type": "string" } },
    "assumed_prior_knowledge": { "type": "array", "items": { "type": "string" } },
    "rationale": { "type": "string" },
    "severity": { "type": "string", "enum": ["low", "medium", "high"] },
    "review_status": { "type": "string", "enum": ["machine_suggested", "subagent_reviewed", "human_accepted", "human_rejected"] },
    "evidence_paths": { "type": "array", "items": { "type": "string" } },
    "human_question": { "type": ["string", "null"] }
  }
}
