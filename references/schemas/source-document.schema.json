{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://4veco.local/references/schemas/source-document.schema.json",
  "title": "SourceDocument",
  "type": "object",
  "additionalProperties": false,
  "required": ["document_id", "path", "source_type", "authority_level"],
  "properties": {
    "document_id": { "type": "string" },
    "path": { "type": "string" },
    "source_type": { "type": "string" },
    "authority_level": { "type": "string" },
    "publisher": { "type": ["string", "null"] },
    "year": { "type": ["integer", "null"] },
    "status": { "type": "string" },
    "refresh_policy": { "type": "string" }
  }
}
