{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://4veco.local/references/schemas/alignment-edge.schema.json",
  "title": "AlignmentEdge",
  "type": "object",
  "additionalProperties": false,
  "required": ["edge_id", "from", "to", "relation", "review_status"],
  "properties": {
    "edge_id": { "type": "string" },
    "from": { "type": "string" },
    "to": { "type": "string" },
    "relation": { "type": "string" },
    "evidence_ids": { "type": "array", "items": { "type": "string" } },
    "strength": { "type": "string" },
    "review_status": { "type": "string" }
  }
}
