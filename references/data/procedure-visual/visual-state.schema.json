{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://4veco.local/references/data/procedure-visual/visual-state.schema.json",
  "title": "Procedure-Visual Visual State",
  "description": "Schema for one semantic visual state in the Procedure-Visual overlay.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "visual_state_id",
    "status",
    "visual_type",
    "semantic_focus",
    "representation",
    "elements",
    "surface_requirements",
    "accessibility",
    "publication"
  ],
  "properties": {
    "visual_state_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "status": {
      "type": "string",
      "enum": [
        "example",
        "draft",
        "pilot",
        "reviewed",
        "deprecated"
      ]
    },
    "visual_type": {
      "type": "string",
      "minLength": 1
    },
    "semantic_focus": {
      "type": "string",
      "minLength": 1
    },
    "representation": {
      "type": "string",
      "minLength": 1
    },
    "elements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "type",
          "role"
        ],
        "properties": {
          "type": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "role": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "axis_role": {
            "type": "string",
            "enum": [
              "horizontal_axis",
              "vertical_axis"
            ]
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "unit": {
            "type": "string",
            "minLength": 1
          },
          "text_nl": {
            "type": "string",
            "minLength": 1
          },
          "visual_encoding": {
            "type": "string",
            "minLength": 1
          },
          "source_ref": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "surface_requirements": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "web_light",
        "web_dark",
        "slide",
        "docx",
        "summary_thumbnail"
      ],
      "properties": {
        "web_light": {
          "type": "boolean"
        },
        "web_dark": {
          "type": "boolean"
        },
        "slide": {
          "type": "boolean"
        },
        "docx": {
          "type": "boolean"
        },
        "summary_thumbnail": {
          "type": "boolean"
        }
      }
    },
    "accessibility": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "meaning_not_color_only",
        "direct_labels_required",
        "non_color_fallback"
      ],
      "properties": {
        "meaning_not_color_only": {
          "type": "boolean"
        },
        "direct_labels_required": {
          "type": "boolean"
        },
        "non_color_fallback": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "publication": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "student_facing_allowed",
        "reason"
      ],
      "properties": {
        "student_facing_allowed": {
          "type": "boolean"
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "blocked_by": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "notes": {
      "type": "string"
    }
  }
}
